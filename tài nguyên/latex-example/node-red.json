        "type": "function",
        "z": "5539a3ae08886664",
        "name": "HandleData",
        "func": "// parse JSON\nif (typeof msg.payload === \"string\") {\n    msg.payload = JSON.parse(msg.payload);\n}\n\n// 4 nhanh: temperature, humidity, alert, ledState\n// KHONG co brightness vi se gay feedback loop voi slider\nreturn [\n    { payload: msg.payload },\n    { payload: msg.payload },\n    { payload: msg.payload },\n    { payload: msg.payload }\n];",
