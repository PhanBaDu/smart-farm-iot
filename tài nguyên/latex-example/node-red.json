    {
        "id": "f781ledbrightfn",
        "type": "function",
        "z": "5539a3ae08886664",
        "name": "Sync slider + switch tu LED status",
        "func": "// Dong bo ca slider va switch tu iot/led/status\n// (keo slider ve 0% => ledState false => switch phai TAT)\nvar p = msg.payload;\nif (typeof p === \"string\") {\n    try { p = JSON.parse(p); } catch (e) { return [null, null]; }\n}\nvar toSlider = null;\nvar toSwitch = null;\nif (p.brightness !== undefined) {\n    toSlider = { payload: Number(p.brightness) };\n}\nif (p.ledState !== undefined) {\n    toSwitch = { payload: p.ledState === true };\n}\nreturn [toSlider, toSwitch];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 600,
        "y": 680,
        "wires": [
            [
                "d2243c92df6d44db"
            ],
            [
                "6832691fa48ba79a"
            ]
        ]
    },
