    {
        "id": "2a9a8088390c80af",
        "type": "function",
        "z": "5539a3ae08886664",
        "name": "Format LED State",
        "func": "// Switch gui true/false -> format + tra ve gia tri slider tuong ung\nvar ledOn = msg.payload === true || msg.payload === \"true\";\nvar toSlider = ledOn ? 100 : 0;\nreturn [\n    { payload: { ledState: ledOn } },   // [0] -> MQTT (lenh cho ESP)\n    { payload: toSlider }               // [1] -> slider (dong bo UI)\n];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
