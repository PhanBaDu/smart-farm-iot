    {
        "id": "a65d9c4fa62dd401",
        "type": "function",
        "z": "5539a3ae08886664",
        "name": "alert",
        "func": "var p = msg.payload;\nif (p.tempAlertHigh)   { msg.payload = \"Nhiet do qua cao!\"; return msg; }\nif (p.tempAlertLow)    { msg.payload = \"Nhiet do qua thap!\";  return msg; }\nif (p.humiAlertHigh)   { msg.payload = \"Do am qua cao!\";  return msg; }\nif (p.humiAlertLow)    { msg.payload = \"Do am qua thap!\";  return msg; }\nreturn null;",
        "outputs": 1,
        "timeout": 0,
